// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum Department {
  DP
  FISCAL
  CONTABIL
}

enum PendingCompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompanyIdentityKind {
  CNPJ
  NAME_REGIME
  CODE
}

enum ImportHistoryStatus {
  DONE
  FAILED
}

enum ProgressStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum IntegrationEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  REVIEW_REQUIRED
  FAILED
  DUPLICATE
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String
  role               Role     @default(USER)
  department         Department?
  isDepartmentLeader Boolean  @default(false)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  auditLogs           AuditLog[]
  tempPassword        UserTempPassword?
  passwordResetTokens PasswordResetToken[]
  decidedCompanies    PendingCompany[] @relation("PendingCompanyDecider")
  progressUpdates     CompanyProgress[]
}

model Company {
  id                    String             @id @default(cuid())
  qtd                   Int?
  codigoInterno         String?
  codigoInternoNormalizado String?          @unique
  razaoSocial           String?
  razaoSocialNormalizada String?
  nomeFantasia          String?
  observacao            String?
  cnpj                  String?
  cnpjNumerico          String?
  raizCnpj              String?
  dataAbertura          DateTime?
  statusCadastral       String?
  telefoneContato       String?
  telefoneContatoNumerico String?
    whatsappContato       String?
    whatsappContatoNumerico String?
    emailContato          String?
    emailContatoAlternativo String?
    ehGrupo               Boolean?
    grupo                 String?
    grupoNormalizado      String?
    regimeTributario      String?
    regimeNormalizado     String?
    sistema               String?
    certificado           String?
    anexo                 String?
    das                   String?
    municipio             String?
    cep                   String?
    logradouro            String?
    numero                String?
    complemento           String?
    bairro                String?
    cidade                String?
    uf                    String?
    cnaePrincipal         String?
    cnaesSecundarios      Json?
    contractStartedAt     DateTime?
    contractEndedAt       DateTime?
    contractPredictedEndedAt DateTime?
    externalOrigin        String?
    fundarmfCaseId        String?
    importedAt            DateTime?
    lastSyncedAt          DateTime?
    syncStatus            String?
  importWarning         String?
  identityKind          CompanyIdentityKind?
  ativo                 Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  pendingCompanies PendingCompany[]
  progressUpdates  CompanyProgress[]
  partners         CompanyPartner[]

  @@unique([cnpjNumerico])
  @@unique([fundarmfCaseId])
  @@unique([razaoSocialNormalizada, regimeNormalizado])
  @@index([cnpjNumerico])
  @@index([codigoInternoNormalizado])
  @@index([raizCnpj])
  @@index([telefoneContatoNumerico])
  @@index([whatsappContatoNumerico])
  @@index([emailContato])
  @@index([emailContatoAlternativo])
  @@index([grupoNormalizado])
  @@index([codigoInterno])
  @@index([sistema])
  @@index([certificado])
  @@index([razaoSocialNormalizada])
    @@index([regimeNormalizado])
    @@index([ativo])
    @@index([contractStartedAt])
    @@index([contractEndedAt])
    @@index([contractPredictedEndedAt])
  }

model CompanyPartner {
  id                  String   @id @default(cuid())
  companyId           String
  nome                String
  nomeNormalizado     String
  cpf                 String?
  cpfNormalizado      String?
  email               String?
  emailNormalizado    String?
  telefone            String?
  telefoneNormalizado  String?
  participacao        Int?
  cargo               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, nomeNormalizado])
  @@index([companyId])
  @@index([nomeNormalizado])
  @@index([cpfNormalizado])
  @@index([emailNormalizado])
  @@index([telefoneNormalizado])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  source      String
  deliveryKey String   @unique
  signature   String?
  timestamp   String?
  payload     Json
  receivedAt  DateTime @default(now())
  processedAt DateTime?

  pendingCompanies PendingCompany[]

  @@index([source, receivedAt])
}

model IntegrationEvent {
  id              String                @id @default(cuid())
  source          String
  eventType       String
  deliveryId      String
  fundarmfCaseId  String?
  companyCnpj     String?
  status          IntegrationEventStatus @default(RECEIVED)
  payload         Json
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([source, deliveryId])
  @@index([source, eventType, createdAt])
  @@index([fundarmfCaseId])
  @@index([companyCnpj])
  @@index([status, createdAt])
}

model PendingCompany {
  id               String              @id @default(cuid())
  source           String
  status           PendingCompanyStatus @default(PENDING)
  receivedAt       DateTime            @default(now())
  decidedAt        DateTime?
  decidedByUserId  String?
  companyId        String?

  // Snapshot dos dados recebidos (para auditoria e reprocessamento)
  payload Json

  // Campos normalizados para busca/triagem
  codigoInterno    String?
  razaoSocial      String?
  nomeFantasia     String?
  cnpj             String?
  cnpjNumerico     String?
  raizCnpj         String?
  grupo            String?
  grupoNormalizado String?
  regimeTributario String?
  sistema          String?
  certificado      String?

  deliveryId String?
  delivery   WebhookDelivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)

  decidedByUser User?   @relation("PendingCompanyDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status, receivedAt])
  @@index([cnpjNumerico])
  @@index([raizCnpj])
  @@index([grupoNormalizado])
}

model CompanyProgress {
  id        String         @id @default(cuid())
  companyId String
  title     String
  status    ProgressStatus @default(TODO)
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUserId String
  createdByUser   User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, startDate])
  @@index([createdByUserId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model ImportHistory {
  id                  String   @id @default(cuid())
  fileName            String
  fileHash            String?  @unique
  status              ImportHistoryStatus @default(DONE)
  total               Int
  created             Int
  updated             Int
  ignored             Int
  suspectedDuplicates Int      @default(0)
  errors              Json?
  report              Json?
  createdAt           DateTime @default(now())

  @@index([createdAt])
}

model UserTempPassword {
  id        String   @id @default(cuid())
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  requestIp String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tokenHash])
  @@index([expiresAt])
}

model RateLimitBucket {
  bucketKey String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}
