// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum Department {
  DP
  FISCAL
  CONTABIL
}

enum PendingCompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProgressStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String
  role               Role     @default(USER)
  department         Department?
  isDepartmentLeader Boolean  @default(false)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  auditLogs           AuditLog[]
  tempPassword        UserTempPassword?
  passwordResetTokens PasswordResetToken[]
  decidedCompanies    PendingCompany[] @relation("PendingCompanyDecider")
  progressUpdates     CompanyProgress[]
}

model Company {
  id               String   @id @default(cuid())
  codigoInterno    String?
  razaoSocial      String?
  nomeFantasia     String?
  cnpj             String?
  cnpjNumerico     String?
  raizCnpj         String?
  grupo            String?
  grupoNormalizado String?
  regimeTributario String?
  sistema          String?
  certificado      String?
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pendingCompanies PendingCompany[]
  progressUpdates  CompanyProgress[]

  @@unique([cnpjNumerico])
  @@index([cnpjNumerico])
  @@index([raizCnpj])
  @@index([grupoNormalizado])
  @@index([codigoInterno])
  @@index([sistema])
  @@index([certificado])
  @@index([ativo])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  source      String
  deliveryKey String   @unique
  signature   String?
  timestamp   String?
  payload     Json
  receivedAt  DateTime @default(now())
  processedAt DateTime?

  pendingCompanies PendingCompany[]

  @@index([source, receivedAt])
}

model PendingCompany {
  id               String              @id @default(cuid())
  source           String
  status           PendingCompanyStatus @default(PENDING)
  receivedAt       DateTime            @default(now())
  decidedAt        DateTime?
  decidedByUserId  String?
  companyId        String?

  // Snapshot dos dados recebidos (para auditoria e reprocessamento)
  payload Json

  // Campos normalizados para busca/triagem
  codigoInterno    String?
  razaoSocial      String?
  nomeFantasia     String?
  cnpj             String?
  cnpjNumerico     String?
  raizCnpj         String?
  grupo            String?
  grupoNormalizado String?
  regimeTributario String?
  sistema          String?
  certificado      String?

  deliveryId String?
  delivery   WebhookDelivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)

  decidedByUser User?   @relation("PendingCompanyDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status, receivedAt])
  @@index([cnpjNumerico])
  @@index([raizCnpj])
  @@index([grupoNormalizado])
}

model CompanyProgress {
  id        String         @id @default(cuid())
  companyId String
  title     String
  status    ProgressStatus @default(TODO)
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUserId String
  createdByUser   User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, startDate])
  @@index([createdByUserId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model ImportHistory {
  id        String   @id @default(cuid())
  fileName  String
  total     Int
  created   Int
  updated   Int
  ignored   Int
  errors    Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model UserTempPassword {
  id        String   @id @default(cuid())
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  requestIp String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tokenHash])
  @@index([expiresAt])
}
